FRAMER_API_KEY=
FRAMER_PROJECT_URL=
FRAMER_HACKS_COLLECTION_NAME=Hileler
FRAMER_GAMES_COLLECTION_NAME=Oyunlar
DEFAULT_STATUS=draft
STRICT_GAME_RELATION=true
SYNC_INPUT_PATH=./data/sample-cheats.json
# file | ai — ai: Oyunlar + Hileler istatistiğine göre oyun seç, Anthropic üret
SYNC_SOURCE=file
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# Bu oyuna bağlı hile sayısı < eşik ise öncelikli aday
HACKS_PER_GAME_THRESHOLD=3
AI_CHEATS_PER_RUN=2
# daily | hourly | random
AI_ROTATION_GRANULARITY=daily
AI_ROTATION_SEED=framer-hacks-sync
MAX_RETRIES=3
RETRY_BASE_MS=400
